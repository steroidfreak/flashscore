# Copy this file to .env and fill in your real values.
# .env is git-ignored and will never be committed.

# ── Required ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional: second recipient using a different bot
# TELEGRAM_BOT_TOKEN_2=friends_bot_token_here
# TELEGRAM_CHAT_ID_2=friends_chat_id_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_PROVIDER=deepseek or claude
DEEPSEEK_API_KEY=sk-...
TELEGRAM_BOT_TOKEN_2=friends_bot_token
  TELEGRAM_CHAT_ID_2=friends_chat_id
# ── Optional (defaults shown) ───────────────────────────────────────────────
# Seconds between each poll of the live tennis page (1 minute)
# CHECK_INTERVAL=60

# Seconds between heartbeat Telegram messages (1 hour)
# HEARTBEAT_INTERVAL=3600

# Rule-based duplicate detection thresholds
# SIMILARITY_THRESHOLD=0.75
# MIN_SIDE_SCORE=0.60

# Run browser without a visible window (must be true on a VPS)
# HEADLESS=true

# Enable Claude Haiku 4.5 AI analysis (requires ANTHROPIC_API_KEY)
# AI_ANALYSIS=true
