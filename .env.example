# Copy this file to .env and fill in your real values.
# .env is git-ignored and will never be committed.

# ── Required ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
MINIMAX_API_KEY=your_minimax_api_key_here

# ── Optional: second Telegram recipient ─────────────────────────────────────
# TELEGRAM_BOT_TOKEN_2=friends_bot_token_here
# TELEGRAM_CHAT_ID_2=friends_chat_id_here

# ── Optional (defaults shown) ───────────────────────────────────────────────
# Seconds between each poll of the live tennis page (2 minutes)
# CHECK_INTERVAL=120

# Rule-based duplicate detection thresholds
# SIMILARITY_THRESHOLD=0.75
# MIN_SIDE_SCORE=0.60

# Run browser without a visible window (must be true on a VPS)
# HEADLESS=true

# Enable MiniMax-M2.7 AI analysis layer (requires MINIMAX_API_KEY)
# AI_ANALYSIS=true
